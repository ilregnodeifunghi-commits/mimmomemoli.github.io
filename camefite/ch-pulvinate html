<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Ch Pulvinate</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
</head>
<body>

    <h1>Ch Pulvinate</h1>
    <div id="loading">Caricamento in corso...</div>
    <div id="table-container"></div>

    <script>
        const urlCSV = "https://raw.githubusercontent.com/ilregnodeifunghi-commits/ilregnodeifunghi-commits.github.io/main/Piante.csv";

        Papa.parse(urlCSV, {
            download: true,
            delimiter: ";", // Se non appare nulla, domani cambieremo in ","
            skipEmptyLines: true,
            complete: function(results) {
                document.getElementById('loading').style.display = 'none';
                console.log("File caricato correttamente!");
                console.log("Righe totali:", results.data.length);
                console.log("Prima riga:", results.data[0]);
                
                // Qui chiameremo la tua funzione renderTable
                // Se non esiste ancora, la scriveremo insieme dopo
            },
            error: function(err) {
                console.error("Errore nel caricamento del CSV:", err);
            }
        });
    </script>
</body>
</html>
