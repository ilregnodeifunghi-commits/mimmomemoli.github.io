<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Ch Pulvinate</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
</head>
<body>

    <h1>Ch Pulvinate</h1>
    <div id="loading">Caricamento in corso...</div>
    <div id="table-container"></div>

   <script>
        // Il "../" è fondamentale perché il file è nella cartella superiore
        const urlFile = "../Piante.txt";

        Papa.parse(urlFile, {
            download: true,
            delimiter: ";", 
            skipEmptyLines: true,
            complete: function(results) {
                // Nasconde il messaggio di caricamento
                document.getElementById('loading').style.display = 'none';
                
                console.log("File caricato correttamente!");
                
                // Visualizzazione dei dati sulla pagina
                const container = document.getElementById('table-container');
                container.innerHTML = "<pre>" + JSON.stringify(results.data, null, 2) + "</pre>";
            },
            error: function(err) {
                console.error("Errore nel caricamento:", err);
                document.getElementById('loading').innerText = "Errore: impossibile caricare il file. Verifica il percorso.";
            }
        });
    </script></body>
</html>
